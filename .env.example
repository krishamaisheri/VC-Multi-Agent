# ============================================
# VC Multi-Agent System Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to git

# ============================================
# Gemini (Gemma) Configuration
# ============================================
# Get your API key from: https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-here

# Gemma model to use for LLM calls (must support generateContent)
GEMINI_MODEL=gemma-4-31b-it

# ============================================
# Qdrant Vector Database Configuration
# ============================================
# For cloud Qdrant instance:
# QDRANT_URL=https://your-instance-id.region.aws.cloud.qdrant.io:6333
# QDRANT_API_KEY=your-qdrant-api-key

# For local Qdrant instance (default):
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Collection name for storing pitches
QDRANT_COLLECTION=vc_pitches

# ============================================
# Voice Processing Configuration
# ============================================
SPEECH_RECOGNITION_LANGUAGE=en-US

# ============================================
# Server Configuration
# ============================================
DEBUG=False
HOST=0.0.0.0
PORT=8000

# ============================================
# Instructions
# ============================================
# 1. Gemini API Key:
#    - Sign up at https://aistudio.google.com/
#    - Generate an API key from settings
#    - Paste it above as GEMINI_API_KEY
#
# 2. Qdrant Database:
#    Option A - Local (free):
#    - Install Qdrant: docker run -p 6333:6333 qdrant/qdrant
#    - Use QDRANT_URL=http://localhost:6333
#
#    Option B - Cloud (recommended for production):
#    - Create account at https://qdrant.tech/
#    - Create a cluster
#    - Copy URL and API key from settings
#
# 3. Keep this file SECRET:
#    - Never commit .env to git (covered by .gitignore)
#    - Don't share your API keys
#    - Rotate keys regularly
