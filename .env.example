# ============================================
# VC Multi-Agent System Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to git

# ============================================
# Gemini (Gemma) Configuration
# ============================================
# Get your API key from: https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini model to use for LLM calls (must support generateContent)
GEMINI_MODEL=gemini-2.5-flash

# ============================================
# Pinecone Vector Database Configuration
# ============================================
# Get a free API key (2GB storage, 1M reads/month, forever free) from:
# https://app.pinecone.io
PINECONE_API_KEY=your-pinecone-api-key-here

# Index is created automatically on first run if it doesn't exist yet.
PINECONE_INDEX_NAME=vc-pitches
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ============================================
# Tavily Web Search Configuration (market research)
# ============================================
# Get a free API key (1,000 credits/month, no card) from: https://tavily.com
# Optional: without it, the market research agent falls back to Tavily's
# rate-limited keyless mode, fine for light/dev use but not production.
TAVILY_API_KEY=your-tavily-api-key-here

# ============================================
# Voice Processing Configuration
# ============================================
SPEECH_RECOGNITION_LANGUAGE=en-US

# ============================================
# Server Configuration
# ============================================
DEBUG=False
HOST=0.0.0.0
PORT=8000

# ============================================
# Admin Panel Configuration
# ============================================
# Sets the password for /admin. Leaving this blank disables admin login
# entirely (requests are always rejected) rather than falling back to
# an insecure default.
ADMIN_PASSWORD=change-me-before-deploying

# ============================================
# Self-Ping / Keep-Alive Configuration
# ============================================
# Pings SELF_PING_URL on an interval so free-tier hosts (Render, Railway,
# etc.) don't spin the app down from inactivity. This MUST be the app's
# PUBLIC deployed URL to actually work - e.g.
# https://your-app.onrender.com/health. Pinging localhost (the default,
# for local testing only) never reaches the platform's edge/proxy, so it
# does not count as external traffic and won't prevent spin-down.
SELF_PING_URL=http://localhost:8000/health
SELF_PING_INTERVAL_MINUTES=13
SELF_PING_ENABLED=True

# ============================================
# Frontend URL (for magic-link emails)
# ============================================
FRONTEND_URL=http://localhost:5173

# ============================================
# Email Configuration (magic-link sign-in)
# ============================================
# Tries SMTP first if SMTP_HOST is set, then Resend if RESEND_API_KEY is
# set, then falls back to logging the link to the console - fine for
# local testing, not for real users.
#
# Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USERNAME=your gmail
# address, SMTP_PASSWORD=an App Password (NOT your regular password) from
# https://myaccount.google.com/apppasswords - requires 2FA enabled first.
# Outlook: SMTP_HOST=smtp.office365.com, SMTP_PORT=587.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=True

# Alternative to SMTP: get a free key from https://resend.com.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# ============================================
# Razorpay Configuration (credit pack payments)
# ============================================
# Get test-mode keys from https://dashboard.razorpay.com (Settings > API Keys)
# and a webhook secret when you configure the payment.captured webhook.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ============================================
# Instructions
# ============================================
# 1. Gemini API Key:
#    - Sign up at https://aistudio.google.com/
#    - Generate an API key from settings
#    - Paste it above as GEMINI_API_KEY
#
# 2. Pinecone Database:
#    - Sign up at https://app.pinecone.io (free, no credit card)
#    - Paste your API key above as PINECONE_API_KEY
#    - The index (PINECONE_INDEX_NAME) is created automatically if missing
#
# 3. Tavily API Key (optional but recommended):
#    - Sign up at https://tavily.com (free, no credit card)
#    - Paste it above as TAVILY_API_KEY
#    - Powers the market research agent's web search
#
# 4. Admin Panel:
#    - Set ADMIN_PASSWORD to something real before deploying.
#    - Set SELF_PING_URL to your public deployed URL + /health once live.
#
# 5. Sign-in and payments:
#    - Set SMTP_HOST/USERNAME/PASSWORD (or RESEND_API_KEY) to actually email magic links (optional for dev)
#    - Set RAZORPAY_KEY_ID/SECRET (test mode) to enable credit pack purchases
#    - Set RAZORPAY_WEBHOOK_SECRET once the payment.captured webhook is configured
#
# 6. Keep this file SECRET:
#    - Never commit .env to git (covered by .gitignore)
#    - Don't share your API keys
#    - Rotate keys regularly
